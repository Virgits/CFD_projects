{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ debug build",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-ggdb",
                "-pedantic-errors",
                "-Wall",
                "-Weffc++",
                "-Wextra",
                "-Wconversion",
                "-Wsign-conversion",
                "-Werror",
                "-std=c++20",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Debug build"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++ release build",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-O2",
                "-DNDEBUG",
                "-pedantic-errors",
                "-Wall",
                "-Weffc++",
                "-Wextra",
                "-Wconversion",
                "-Wsign-conversion",
                "-Werror",
                "-std=c++20",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Release build"
        }
    ],
    "version": "2.0.0"
}
